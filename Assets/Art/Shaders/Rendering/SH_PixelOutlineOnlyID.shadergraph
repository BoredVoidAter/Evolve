{
    "m_SGVersion": 1,
    "m_Type": "UnityEditor.ShaderGraph.CustomFunctionNode",
    "m_ObjectId": "635dd6952c03451189d60d74fbec92e4",
    "m_Group": {
        "m_Id": ""
    },
    "m_Name": "GetForegroundUV (Custom Function)",
    "m_DrawState": {
        "m_Expanded": true,
        "m_Position": {
            "serializedVersion": "2",
            "x": -270.99993896484377,
            "y": -502.9999694824219,
            "width": 256.9998474121094,
            "height": 94.0
        }
    },
    "m_Slots": [
        {
            "m_Id": "35ee98a81dfc4f6bbf9bda22b75e6369"
        },
        {
            "m_Id": "d7e28b76b105401fbc73147300fec8ba"
        }
    ],
    "synonyms": [
        "code",
        "HLSL"
    ],
    "m_Precision": 0,
    "m_PreviewExpanded": false,
    "m_DismissedVersion": 0,
    "m_PreviewMode": 0,
    "m_CustomColors": {
        "m_SerializableColors": []
    },
    "m_SourceType": 1,
    "m_FunctionName": "GetForegroundUV",
    "m_FunctionSource": "",
    "m_FunctionSourceUsePragmas": true,
    "m_FunctionBody": "float2 texel = 1.0 / _ScreenParams.xy;\nForegroundUV = UV;\nfloat minDepth = 99999.0;\n\n// We check the center pixel and 4 neighbors\nfloat2 offsets[5] = { float2(0,0), float2(0, 1), float2(0, -1), float2(1, 0), float2(-1, 0) };\n\nfor(int i = 0; i < 5; i++) {\n    // Step outwards to ensure we grab a pixel fully inside the object\n    // (Note: To match your comment about 1.5 texels, you might want to use: offsets[i] * 1.5 * texel)\n    float2 checkUV = UV + offsets[i] * texel; \n    \n    // Sample depth at this offset\n    float rawDepth = SHADERGRAPH_SAMPLE_SCENE_DEPTH(checkUV);\n    \n    // Calculate accurate depth based on projection type\n    float eyeDepth;\n    if (unity_OrthoParams.w == 1.0) {\n        // Orthographic Camera\n        #if UNITY_REVERSED_Z\n            eyeDepth = 1.0 - rawDepth;\n        #else\n            eyeDepth = rawDepth;\n        #endif\n    } else {\n        // Perspective Camera\n        eyeDepth = LinearEyeDepth(rawDepth, _ZBufferParams);\n    }\n\n    // If this pixel is closer to the camera, save its UV!\n    if(eyeDepth < minDepth) {\n        minDepth = eyeDepth;\n        ForegroundUV = checkUV;\n    }\n}"
}

