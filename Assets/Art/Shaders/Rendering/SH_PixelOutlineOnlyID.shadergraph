    "m_SourceType": 1,
    "m_FunctionName": "CalculateEdges",
    "m_FunctionSource": "",
    "m_FunctionSourceUsePragmas": true,
    "m_FunctionBody": "float isDiff = length(ID_Center - ID_Right) + length(ID_Center - ID_Top);\n\nIsEdge = (isDiff > ID_Threshold) ? 1.0:0.0;\n"
}

