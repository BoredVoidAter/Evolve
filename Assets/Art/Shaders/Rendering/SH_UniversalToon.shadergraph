{
    "m_SGVersion": 1,
    "m_Type": "UnityEditor.ShaderGraph.CustomFunctionNode",
    "m_ObjectId": "098a73de3e3e4568894239bc170b3614",
    "m_Group": {
        "m_Id": "222396658455473085b5a750433e69f5"
    },
    "m_Name": "GetMainLight (Custom Function)",
    "m_DrawState": {
        "m_Expanded": true,
        "m_Position": {
            "serializedVersion": "2",
            "x": -937.0000610351563,
            "y": -645.0,
