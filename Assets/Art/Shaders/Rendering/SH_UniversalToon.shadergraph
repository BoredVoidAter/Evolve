    "m_Slots": [
        {
            "m_Id": "aa4993d9ea4442e4986e11a01c253c30"
        },
        {
            "m_Id": "5540639bd0474deeb4b47efa0241e9b8"
        },
        {
            "m_Id": "660f75fedc2c47099e55de75a35fbfb7"
        },
        {
            "m_Id": "b290d6b39b88471da2c752541c3038be"
        }
    ],
    "synonyms": [
        "code",
        "HLSL"
    ],
    "m_Precision": 0,
    "m_PreviewExpanded": false,
    "m_DismissedVersion": 0,
    "m_PreviewMode": 0,
    "m_CustomColors": {
        "m_SerializableColors": []
    },
    "m_SourceType": 1,
    "m_FunctionName": "GetMainLight",
    "m_FunctionSource": "",
    "m_FunctionSourceUsePragmas": true,
    "m_FunctionBody": "#if defined(SHADERGRAPH_PREVIEW) || !defined(UNIVERSAL_LIGHTING_INCLUDED)\n    // Safe fallback for previews and non-lit passes (like Depth/Shadows)\n    Direction = float3(0.5, 0.5, 0);\n    Color = float3(1, 1, 1);\n    ShadowAtten = 1.0;\n#else\n    // Actually grab the light data\n    Light mainLight = GetMainLight(TransformWorldToShadowCoord(WorldPos));\n    Direction = mainLight.direction;\n    Color = mainLight.color;\n    \n    // URP calculates shadows. If you have no shadows cast, this defaults to 1.\n    ShadowAtten = mainLight.shadowAttenuation * mainLight.distanceAttenuation;\n#endif"
}

