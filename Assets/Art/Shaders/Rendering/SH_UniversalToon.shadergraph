{
    "m_SGVersion": 1,
    "m_Type": "UnityEditor.ShaderGraph.CustomFunctionNode",
    "m_ObjectId": "098a73de3e3e4568894239bc170b3614",
    "m_Group": {
        "m_Id": ""
    },
    "m_Name": "GetMainLight (Custom Function)",
    "m_DrawState": {
        "m_Expanded": true,
        "m_Position": {
            "serializedVersion": "2",
            "x": 343.2647705078125,
            "y": -268.4752197265625,
            "width": 0.0,
            "height": 0.0
        }
    },
    "m_Slots": [
        {
            "m_Id": "aa4993d9ea4442e4986e11a01c253c30"
        },
        {
            "m_Id": "5540639bd0474deeb4b47efa0241e9b8"
        },
        {
            "m_Id": "660f75fedc2c47099e55de75a35fbfb7"
        },
        {
            "m_Id": "b290d6b39b88471da2c752541c3038be"
        }
    ],
    "synonyms": [
        "code",
        "HLSL"
    ],
    "m_Precision": 0,
    "m_PreviewExpanded": false,
    "m_DismissedVersion": 0,
    "m_PreviewMode": 0,
    "m_CustomColors": {
        "m_SerializableColors": []
    },
    "m_SourceType": 1,
    "m_FunctionName": "GetMainLight",
    "m_FunctionSource": "",
    "m_FunctionSourceUsePragmas": true,
    "m_FunctionBody": "#ifdef SHADERGRAPH_PREVIEW\n    Direction = float3(0.5, 0.5, 0);\n    Color = float3(1, 1, 1);\n    ShadowAtten = 1.0;\n#else\n    #if defined(UNIVERSAL_LIGHTING_INCLUDED)\n        // Get the main light from URP\n        Light mainLight = GetMainLight(TransformWorldToShadowCoord(WorldPos));\n        Direction = mainLight.direction;\n        Color = mainLight.color;\n        // Combine shadow map occlusion with distance falloff\n        ShadowAtten = mainLight.shadowAttenuation * mainLight.distanceAttenuation;\n    #else\n        Direction = float3(0.5, 0.5, 0);\n        Color = float3(1, 1, 1);\n        ShadowAtten = 1.0;\n    #endif\n#endif"
}

