    "m_SourceType": 1,
    "m_FunctionName": "CalculateEdges",
    "m_FunctionSource": "",
    "m_FunctionSourceUsePragmas": true,
    "m_FunctionBody": "// Calculate difference between pixels\nfloat idDiff = length(ID_Center - ID_Right) + length(ID_Center - ID_Top);\nfloat normDiff = length(Norm_Center - Norm_Right) + length(Norm_Center - Norm_Top);\n\n// Return 1 if it's an edge, 0 if it isn't\nIsEdge = (idDiff > ID_Threshold || normDiff > Norm_Threshold) ? 1.0 : 0.0;"
}

