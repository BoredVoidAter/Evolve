<file path="Assets/Scripts/CameraSystem/ModernPixelPerfectCamera.cs">
 1: using UnityEngine;
 2: [RequireComponent(typeof(Camera))]
 3: public class ModernPixelPerfectCamera : MonoBehaviour
 4: {
 5:     public RenderTexture targetRenderTexture;
 6:     private Vector3 _targetPosition;
 7:     private Camera _cam;
 8:     void Start()
 9:     {
10:         _cam = GetComponent<Camera>();
11:         _targetPosition = transform.position;
12:     }
13:     public void SetTargetPosition(Vector3 newPos)
14:     {
15:         _targetPosition = newPos;
16:     }
17:     void LateUpdate()
18:     {
19:         if (targetRenderTexture == null) return;
20:         float orthoHeight = _cam.orthographicSize * 2f;
21:         float unitsPerPixelY = orthoHeight / targetRenderTexture.height;
22:         float unitsPerPixelX = unitsPerPixelY;
23:         float snappedX = Mathf.Round(_targetPosition.x / unitsPerPixelX) * unitsPerPixelX;
24:         float snappedY = Mathf.Round(_targetPosition.y / unitsPerPixelY) * unitsPerPixelY;
25:         transform.position = new Vector3(snappedX, snappedY, _targetPosition.z);
26:     }
27: }
</file>

<file path="Assets/Scripts/Rendering/Components/IDMapObject.cs">
 1: using UnityEngine;
 2: [RequireComponent(typeof(Renderer))]
 3: public class IDMapObject : MonoBehaviour
 4: {
 5:     private static readonly int EncodedIDProp = Shader.PropertyToID("_EncodedSubjectID");
 6:     private static MaterialPropertyBlock _mpb;
 7:     [Tooltip("If 0, the script assigns a random ID. If non-zero, uses this ID (e.g., for grouping limbs).")]
 8:     public uint groupId = 0;
 9:     void Start()
10:     {
11:         if (_mpb == null) _mpb = new MaterialPropertyBlock();
12:         Renderer rend = GetComponent<Renderer>();
13:         if (groupId == 0)
14:         {
15:             groupId = (uint)Random.Range(1, int.MaxValue);
16:         }
17:         Color32 idColor = new Color32(
18:             (byte)((groupId) & 0xFF),
19:             (byte)((groupId >> 8) & 0xFF),
20:             (byte)((groupId >> 16) & 0xFF),
21:             (byte)((groupId >> 24) & 0xFF)
22:         );
23:         rend.GetPropertyBlock(_mpb);
24:         _mpb.SetColor(EncodedIDProp, idColor);
25:         rend.SetPropertyBlock(_mpb);
26:     }
27: }
</file>

<file path="Assets/Scripts/Rendering/Features/IDMapRendererFeature.cs">
 1: using UnityEngine;
 2: using UnityEngine.Rendering;
 3: using UnityEngine.Rendering.RenderGraphModule;
 4: using UnityEngine.Rendering.Universal;
 5: public class IDMapRendererFeature : ScriptableRendererFeature
 6: {
 7:     class IDMapPass : ScriptableRenderPass
 8:     {
 9:         private Material overrideMaterial;
10:         private LayerMask layerMask;
11:         private ShaderTagId shaderTagId = new ShaderTagId("UniversalForward");
12:         public IDMapPass(Material material, LayerMask layerMask)
13:         {
14:             this.overrideMaterial = material;
15:             this.layerMask = layerMask;
16:             this.renderPassEvent = RenderPassEvent.AfterRenderingOpaques;
17:         }
18:         private class PassData
19:         {
20:             public RendererListHandle rendererList;
21:             public TextureHandle idMapTexture;
22:         }
23:         public override void RecordRenderGraph(RenderGraph renderGraph, ContextContainer frameData)
24:         {
25:             if (overrideMaterial == null) return;
26:             UniversalRenderingData renderingData = frameData.Get<UniversalRenderingData>();
27:             UniversalCameraData cameraData = frameData.Get<UniversalCameraData>();
28:             UniversalResourceData resourceData = frameData.Get<UniversalResourceData>();
29:             RenderTextureDescriptor desc = cameraData.cameraTargetDescriptor;
30:             desc.colorFormat = RenderTextureFormat.ARGB32;
31:             desc.depthBufferBits = 0;
32:             TextureHandle idMapTex = UniversalRenderer.CreateRenderGraphTexture(renderGraph, desc, "_IDMap", false);
33:             SortingCriteria sortingCriteria = cameraData.defaultOpaqueSortFlags;
34:             DrawingSettings drawingSettings = new DrawingSettings(shaderTagId, new SortingSettings(cameraData.camera) { criteria = sortingCriteria });
35:             drawingSettings.overrideMaterial = overrideMaterial;
36:             FilteringSettings filteringSettings = new FilteringSettings(RenderQueueRange.opaque, layerMask);
37:             RendererListParams listParams = new RendererListParams(renderingData.cullResults, drawingSettings, filteringSettings);
38:             RendererListHandle rendererList = renderGraph.CreateRendererList(listParams);
39:             using (var builder = renderGraph.AddRasterRenderPass<PassData>("IDMapRenderPass", out var passData))
40:             {
41:                 passData.rendererList = rendererList;
42:                 passData.idMapTexture = idMapTex;
43:                 builder.SetRenderAttachment(idMapTex, 0, AccessFlags.Write);
44:                 builder.SetRenderAttachmentDepth(resourceData.activeDepthTexture, AccessFlags.Read);
45:                 builder.UseRendererList(rendererList);
46:                 builder.AllowGlobalStateModification(true);
47:                 builder.SetGlobalTextureAfterPass(idMapTex, Shader.PropertyToID("_IDMap"));
48:                 builder.SetRenderFunc((PassData data, RasterGraphContext context) =>
49:                 {
50:                     context.cmd.ClearRenderTarget(false, true, Color.black);
51:                     context.cmd.DrawRendererList(data.rendererList);
52:                 });
53:             }
54:         }
55:     }
56:     public Material overrideMaterial;
57:     public LayerMask layerMask;
58:     private IDMapPass idMapPass;
59:     public override void Create()
60:     {
61:         idMapPass = new IDMapPass(overrideMaterial, layerMask);
62:     }
63:     public override void AddRenderPasses(ScriptableRenderer renderer, ref RenderingData renderingData)
64:     {
65:         if (overrideMaterial != null && (renderingData.cameraData.cameraType == CameraType.Game || renderingData.cameraData.cameraType == CameraType.SceneView))
66:         {
67:             renderer.EnqueuePass(idMapPass);
68:         }
69:     }
70: }
</file>

